  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'CMD=$(cat | jq -r \".tool_input.command // empty\"); if [ -z \"$CMD\" ]; then exit 0; fi; PATTERNS=\"(^|[;\\&\\|\\`\\$\\(])\\s*(curl|wget|nc|netcat|ncat|socat|ssh|scp|rsync|telnet|ftp|sftp|nmap)\\b\" ; PATTERNS2=\"(^|[;\\&\\|\\`\\$\\(])\\s*(sudo|su|doas|pkexec|chmod|chown|chgrp|passwd|usermod|useradd|groupadd|mount|umount|chroot)\\b\" ; PATTERNS3=\"(^|[;\\&\\|\\`\\$\\(])\\s*(docker|podman|kubectl|helm|terraform|vault|aws|az|gcloud|eksctl|consul|nomad|packer)\\b\" ; PATTERNS4=\"(^|[;\\&\\|\\`\\$\\(])\\s*(python3?|node|ruby|perl|php)\\s+-(c|e|r)\\b\" ; PATTERNS5=\"(^|[;\\&\\|\\`\\$\\(])\\s*(sh|bash|zsh|dash|ksh)\\s+-[ci]\" ; PATTERNS6=\"(^|[;\\&\\|\\`\\$\\(])\\s*(eval|exec|source|nohup)\\b\" ; PATTERNS7=\"(^|[;\\&\\|\\`\\$\\(])\\s*(base64|xxd|openssl)\\b\" ; PATTERNS8=\"(cat|head|tail|less|more|strings|xxd|od|hexdump|grep|awk|sed).*(\\.env|\\.pem|\\.key|id_rsa|id_ed25519|id_ecdsa|credentials|secret|token|password|shadow|passwd|kubeconfig|tfvars|vault\\.json|service.account)\" ; PATTERNS9=\"(^|[;\\&\\|\\`\\$\\(])\\s*(rm\\s+-r|shred|srm|wipe|mkfifo|mknod|dd\\s)\\b\" ; PATTERNSA=\"(^|[;\\&\\|\\`\\$\\(])\\s*(crontab|launchctl|systemctl|schtasks|systemd-run|at\\b|batch\\b)\" ; PATTERNSB=\"(^|[;\\&\\|\\`\\$\\(])\\s*(powershell|pwsh|cmd\\.exe|wscript|cscript|mshta|rundll32|regsvr32|msiexec|certutil|bitsadmin|reg\\.exe|regedit|netsh|runas|psexec|sc\\.exe|bcdedit|winrm)\\b\" ; PATTERNSC=\"\\|\\s*(sh|bash|zsh|dash|python|node|ruby|perl|php)\\b\" ; PATTERNSD=\"(^|[;\\&\\|\\`\\$\\(])\\s*(op|bw|rbw|lpass|pass)\\s\" ; for P in \"$PATTERNS\" \"$PATTERNS2\" \"$PATTERNS3\" \"$PATTERNS4\" \"$PATTERNS5\" \"$PATTERNS6\" \"$PATTERNS7\" \"$PATTERNS8\" \"$PATTERNS9\" \"$PATTERNSA\" \"$PATTERNSB\" \"$PATTERNSC\" \"$PATTERNSD\"; do if echo \"$CMD\" | grep -qEi \"$P\"; then echo \"{\\\"decision\\\": \\\"block\\\", \\\"reason\\\": \\\"Security policy: command matched forbidden pattern\\\"}\" >&2; exit 2; fi; done; exit 0'"
          }
        ]
      }
    ]
  },

  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  }
